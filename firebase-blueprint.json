{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "chatBackground": { "type": "string" },
        "privacy": { "type": "object" },
        "notificationSounds": { "type": "object" },
        "sessionVersion": { "type": "number" },
        "friends": { "type": "array", "items": { "type": "string" } },
        "isDeveloper": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "forceLogoutSignal": { "type": "number" },
        "specialColor": { "type": "string" },
        "magicUnlockedAt": { "type": "string", "format": "date-time" },
        "animatedColorsUnlockedAt": { "type": "string", "format": "date-time" },
        "nameColor": { "type": "string" },
        "reels": { "type": "array" }
      },
      "required": ["uid", "phoneNumber"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isGroup": { "type": "boolean" },
        "groupName": { "type": "string" },
        "groupPhoto": { "type": "string" },
        "admins": { "type": "array", "items": { "type": "string" } },
        "memberRoles": { "type": "object" },
        "isLocked": { "type": "boolean" },
        "typing": { "type": "object" }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    },
    "Game": {
      "title": "Game",
      "description": "A multiplayer game session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["dominoes", "blackjack", "xo", "chess", "ludo"] },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "players": { "type": "array", "items": { "type": "string" } },
        "turn": { "type": "string" },
        "board": { "type": "object" },
        "hands": { "type": "object" },
        "scores": { "type": "object" },
        "positions": { "type": "object" },
        "lastRoll": { "type": "number" },
        "lastAction": { "type": "string" },
        "reason": { "type": "string" },
        "fen": { "type": "string" },
        "winner": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "status", "players", "updatedAt"]
    },
    "Call": {
      "title": "Call",
      "description": "WebRTC Call Signaling",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "chatId": { "type": "string" },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "status": { "type": "string", "enum": ["calling", "active", "ended", "rejected"] },
        "type": { "type": "string", "enum": ["voice", "video"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["callerId", "receiverId", "chatId", "status", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Game sessions"
    },
    "/calls/{callId}": {
      "schema": "Call",
      "description": "Call signaling sessions"
    },
    "/calls/{callId}/callerCandidates/{candidateId}": {
      "schema": "object",
      "description": "ICE candidates from caller"
    },
    "/calls/{callId}/receiverCandidates/{candidateId}": {
      "schema": "object",
      "description": "ICE candidates from receiver"
    }
  }
}
