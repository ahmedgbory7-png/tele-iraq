rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - phoneNumber: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - status: string (optional)
    //   - lastSeen: timestamp (optional)
    //
    // Collection: chats
    // Document ID: chatId
    // Fields:
    //   - participants: list of strings (required, UIDs)
    //   - lastMessage: map (optional)
    //   - updatedAt: timestamp (required)
    //
    // Collection: chats/{chatId}/messages
    // Document ID: messageId
    // Fields:
    //   - chatId: string (required)
    //   - senderId: string (required)
    //   - text: string (required)
    //   - type: string (required, enum: text, image, video)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      // For updates, the UID should already be in the document and match request.auth.uid
      // If UID is provided in the write (or present in merged result), it must match the owner
      let hasUid = 'uid' in data;
      return (!hasUid || (data.uid == request.auth.uid || data.uid == 'teleiraq-system')) &&
             (!('phoneNumber' in data) || data.phoneNumber is string) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000000)) &&
             (!('status' in data) || (data.status is string && data.status.size() <= 300)) &&
             (!('lastSeen' in data) || (data.lastSeen == null || data.lastSeen is timestamp)) &&
             (!('chatBackground' in data) || (data.chatBackground is string && data.chatBackground.size() <= 1000)) &&
             (!('privacy' in data) || data.privacy is map) &&
             (!('notificationSounds' in data) || data.notificationSounds is map) &&
             (!('sessionVersion' in data) || data.sessionVersion is number) &&
             (!('friends' in data) || (data.friends is list && data.friends.size() <= 1000)) &&
             (!('blockedUsers' in data) || (data.blockedUsers is list && data.blockedUsers.size() <= 1000)) &&
             (!('magicUnlockedAt' in data) || (data.magicUnlockedAt == null || data.magicUnlockedAt is timestamp)) &&
             (!('animatedColorsUnlockedAt' in data) || (data.animatedColorsUnlockedAt == null || data.animatedColorsUnlockedAt is timestamp)) &&
             (!('nameColor' in data) || (data.nameColor is string && data.nameColor.size() <= 50)) &&
             (!('reels' in data) || (data.reels is list && data.reels.size() <= 100)) &&
             (!('reelsCount' in data) || data.reelsCount is number) &&
             (!('lastReelAt' in data) || (data.lastReelAt == null || data.lastReelAt is timestamp));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['participants', 'updatedAt']) &&
             data.participants is list &&
             data.participants.size() >= 1 &&
             data.participants.size() <= 500 &&
             (!('isGroup' in data) || data.isGroup is bool) &&
             (!('groupName' in data) || (data.groupName is string && data.groupName.size() <= 100)) &&
             (!('groupPhoto' in data) || (data.groupPhoto is string && data.groupPhoto.size() <= 1000000)) &&
             (!('admins' in data) || (data.admins is list && data.admins.size() <= 100)) &&
             (!('memberRoles' in data) || data.memberRoles is map) &&
             (!('isLocked' in data) || data.isLocked is bool) &&
             (!('typing' in data) || data.typing is map) &&
             (!('lastMessage' in data) || data.lastMessage is map) &&
             (!('hiddenFor' in data) || (data.hiddenFor is list && data.hiddenFor.size() <= 500)) &&
             (!('call' in data) || data.call is map) &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'type', 'createdAt']) &&
             data.chatId is string &&
             (data.senderId == request.auth.uid || data.senderId == 'teleiraq-system') &&
             (!('text' in data) || (data.text is string && data.text.size() <= 5000)) &&
             data.type in ['text', 'image', 'video', 'file', 'location', 'voice'] &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() <= 1000000)) &&
             (!('fileName' in data) || (data.fileName is string && data.fileName.size() <= 200)) &&
             (!('location' in data) || (data.location is map && data.location.latitude is number && data.location.longitude is number)) &&
             (!('replyTo' in data) || (data.replyTo is map && data.replyTo.id is string && ('text' in data.replyTo || 'senderName' in data.replyTo))) &&
             (!('reactions' in data) || data.reactions is map) &&
             (!('read' in data) || data.read is bool) &&
             (!('gameId' in data) || data.gameId is string) &&
             (!('isEdited' in data) || data.isEdited is bool) &&
             data.createdAt is timestamp;
    }

    // Rules
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['lastSeen'])) ||
        (incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'status', 'chatBackground', 'privacy', 'notificationSounds', 'sessionVersion', 'friends', 'blockedUsers', 'magicUnlockedAt', 'animatedColorsUnlockedAt', 'nameColor', 'reels', 'reelsCount', 'lastReelAt']))
      );

      match /userReels/{reelId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['url', 'createdAt', 'userId']) &&
                      incoming().url is string && incoming().url.size() <= 1000000 &&
                      incoming().createdAt is timestamp &&
                      incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      function isParticipant() {
        return isAuthenticated() && request.auth.uid in resource.data.participants;
      }
      function isChatAdmin() {
        return isParticipant() && request.auth.uid in resource.data.admins;
      }

      allow read: if isParticipant();
      allow create: if isValidId(chatId) && isAuthenticated() && request.auth.uid in incoming().participants && isValidChat(incoming());
      allow update: if isParticipant() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['typing'])) ||
        (incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt', 'hiddenFor', 'call'])) ||
        (isChatAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['groupName', 'groupPhoto', 'admins', 'memberRoles', 'isLocked', 'participants']))
      );
      allow delete: if isParticipant() && (!('isGroup' in resource.data) || !resource.data.isGroup || (('admins' in resource.data) && request.auth.uid in resource.data.admins));

      match /messages/{messageId} {
        function getChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        function isLocked() {
          return 'isLocked' in getChat() && getChat().isLocked == true;
        }
        function isSenderAdmin() {
          return ('admins' in getChat()) && request.auth.uid in getChat().admins;
        }

        allow read: if isAuthenticated() && request.auth.uid in getChat().participants;
        allow create: if isValidId(messageId) && isAuthenticated() && 
                      request.auth.uid in getChat().participants &&
                      (!isLocked() || isSenderAdmin()) &&
                      isValidMessage(incoming());
        allow update: if isAuthenticated() && 
                      request.auth.uid in getChat().participants &&
                      (
                        (incoming().diff(existing()).affectedKeys().hasOnly(['read']) && incoming().read == true) ||
                        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions'])) ||
                        (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited']) && isValidMessage(incoming()))
                      );
        allow delete: if isAuthenticated() && 
                      (existing().senderId == request.auth.uid || 
                       request.auth.uid in getChat().participants);
      }
    }

    match /games/{gameId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.players;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.players;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.players;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.players;
    }
  }
}
