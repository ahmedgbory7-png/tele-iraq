rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - phoneNumber: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - status: string (optional)
    //   - lastSeen: timestamp (optional)
    //
    // Collection: chats
    // Document ID: chatId
    // Fields:
    //   - participants: list of strings (required, UIDs)
    //   - lastMessage: map (optional)
    //   - updatedAt: timestamp (required)
    //
    // Collection: chats/{chatId}/messages
    // Document ID: messageId
    // Fields:
    //   - chatId: string (required)
    //   - senderId: string (required)
    //   - text: string (required)
    //   - type: string (required, enum: text, image, video)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isDeveloper() {
      return isAuthenticated() && (
        request.auth.token.email == 'isofiq@teleiraq.app' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true)
      );
    }

    function isValidUser(data) {
      let isDev = isAuthenticated() && request.auth.token.email == 'isofiq@teleiraq.app';
      let hasUid = 'uid' in data;
      return (!hasUid || (data.uid == request.auth.uid || data.uid == 'teleiraq-system' || isDev)) &&
             (!('phoneNumber' in data) || data.phoneNumber is string) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000000)) &&
             (!('status' in data) || (data.status is string && data.status.size() <= 300)) &&
             (!('lastSeen' in data) || (data.lastSeen == null || data.lastSeen is timestamp)) &&
             (!('chatBackground' in data) || (data.chatBackground is string && data.chatBackground.size() <= 1000000)) &&
             (!('username' in data) || (data.username is string && data.username.size() <= 50)) &&
             (!('birthDate' in data) || (data.birthDate is string && data.birthDate.size() <= 20)) &&
             (!('city' in data) || (data.city is string && data.city.size() <= 50)) &&
             (!('hobbies' in data) || (data.hobbies is string && data.hobbies.size() <= 200)) &&
             (!('privacy' in data) || data.privacy is map) &&
             (!('notificationSounds' in data) || data.notificationSounds is map) &&
             (!('sessionVersion' in data) || data.sessionVersion is number) &&
             (!('friends' in data) || (data.friends is list && data.friends.size() <= 1000)) &&
             (!('friendDetails' in data) || data.friendDetails is map) &&
             (!('blockedUsers' in data) || (data.blockedUsers is list && data.blockedUsers.size() <= 1000)) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('isDeveloper' in data) || data.isDeveloper is bool) &&
             (!('isBanned' in data) || data.isBanned is bool) &&
             (!('forceLogoutSignal' in data) || data.forceLogoutSignal is number) &&
             (!('specialColor' in data) || (data.specialColor is string && data.specialColor.size() <= 50)) &&
             (!('verifiedAt' in data) || (data.verifiedAt == null || data.verifiedAt is timestamp)) &&
             (!('magicUnlockedAt' in data) || (data.magicUnlockedAt == null || data.magicUnlockedAt is timestamp)) &&
             (!('magic2UnlockedAt' in data) || (data.magic2UnlockedAt == null || data.magic2UnlockedAt is timestamp)) &&
             (!('magic3UnlockedAt' in data) || (data.magic3UnlockedAt == null || data.magic3UnlockedAt is timestamp)) &&
             (!('magic4UnlockedAt' in data) || (data.magic4UnlockedAt == null || data.magic4UnlockedAt is timestamp)) &&
             (!('magicIraqUnlockedAt' in data) || (data.magicIraqUnlockedAt == null || data.magicIraqUnlockedAt is timestamp)) &&
             (!('animatedColorsUnlockedAt' in data) || (data.animatedColorsUnlockedAt == null || data.animatedColorsUnlockedAt is timestamp)) &&
             (!('nameColor' in data) || (data.nameColor is string && data.nameColor.size() <= 50)) &&
             (!('reels' in data) || (data.reels is list && data.reels.size() <= 100)) &&
             (!('reelsCount' in data) || data.reelsCount is number) &&
             (!('lastReelAt' in data) || (data.lastReelAt == null || data.lastReelAt is timestamp));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['participants', 'updatedAt']) &&
             data.participants is list &&
             data.participants.size() >= 1 &&
             data.participants.size() <= 500 &&
             (!('isGroup' in data) || data.isGroup is bool) &&
             (!('groupName' in data) || (data.groupName is string && data.groupName.size() <= 100)) &&
             (!('groupPhoto' in data) || (data.groupPhoto is string && data.groupPhoto.size() <= 1000000)) &&
             (!('participantProfiles' in data) || data.participantProfiles is map) &&
             (!('admins' in data) || (data.admins is list && data.admins.size() <= 100)) &&
             (!('memberRoles' in data) || data.memberRoles is map) &&
             (!('isLocked' in data) || data.isLocked is bool) &&
             (!('typing' in data) || data.typing is map) &&
             (!('lastMessage' in data) || data.lastMessage is map) &&
             (!('hiddenFor' in data) || (data.hiddenFor is list && data.hiddenFor.size() <= 500)) &&
             (!('call' in data) || data.call is map) &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'type', 'createdAt']) &&
             data.chatId is string &&
             (data.senderId == request.auth.uid || data.senderId == 'teleiraq-system') &&
             (!('text' in data) || (data.text is string && data.text.size() <= 5000)) &&
             data.type in ['text', 'image', 'video', 'file', 'location', 'voice', 'sticker', 'system'] &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() <= 1000000)) &&
             (!('fileName' in data) || (data.fileName is string && data.fileName.size() <= 200)) &&
             (!('location' in data) || (data.location is map && data.location.latitude is number && data.location.longitude is number)) &&
             (!('replyTo' in data) || (data.replyTo is map && data.replyTo.id is string && ('text' in data.replyTo || 'senderName' in data.replyTo))) &&
             (!('reactions' in data) || data.reactions is map) &&
             (!('read' in data) || data.read is bool) &&
             (!('gameId' in data) || data.gameId is string) &&
             (!('isEdited' in data) || data.isEdited is bool) &&
             data.createdAt is timestamp;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['type', 'status', 'players', 'updatedAt']) &&
             data.type in ['dominoes', 'blackjack', 'xo', 'chess', 'ludo'] &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.players is list &&
             data.players.size() >= 1 &&
             (!('turn' in data) || data.turn is string) &&
             (!('board' in data) || data.board is list || data.board is map) &&
             (!('hands' in data) || data.hands is map) &&
             (!('scores' in data) || data.scores is map) &&
             (!('positions' in data) || data.positions is map) &&
             (!('lastRoll' in data) || data.lastRoll == null || data.lastRoll is number) &&
             (!('lastAction' in data) || (data.lastAction is string && data.lastAction.size() <= 100)) &&
             (!('reason' in data) || (data.reason is string && data.reason.size() <= 200)) &&
             (!('fen' in data) || (data.fen is string && data.fen.size() <= 1000)) &&
             (!('winner' in data) || (data.winner == null || data.winner is string)) &&
             data.updatedAt is timestamp;
    }

    function isValidCall(data) {
      return data.keys().hasAll(['callerId', 'receiverId', 'chatId', 'status', 'type', 'createdAt']) &&
             data.callerId is string &&
             data.receiverId is string &&
             data.chatId is string &&
             data.status in ['calling', 'active', 'ended', 'rejected'] &&
             data.type in ['voice', 'video'] &&
             (!('offer' in data) || data.offer is map) &&
             (!('answer' in data) || data.answer is map) &&
             data.createdAt is timestamp;
    }

    // Rules
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && 
                    !incoming().keys().hasAny(['isDeveloper', 'isBanned', 'forceLogoutSignal', 'specialColor', 'isVerified']);
      allow update: if isValidId(userId) && (isOwner(userId) || isDeveloper()) && isValidUser(incoming()) && (
        isDeveloper() || (
          isOwner(userId) &&
          !incoming().diff(existing()).affectedKeys().hasAny(['isDeveloper', 'isBanned', 'forceLogoutSignal', 'specialColor', 'isVerified']) &&
          (
            (incoming().diff(existing()).affectedKeys().hasOnly(['lastSeen'])) ||
            (incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'username', 'birthDate', 'city', 'hobbies', 'photoURL', 'status', 'chatBackground', 'privacy', 'notificationSounds', 'sessionVersion', 'friends', 'friendDetails', 'blockedUsers', 'magicUnlockedAt', 'magic2UnlockedAt', 'magic3UnlockedAt', 'magic4UnlockedAt', 'magicIraqUnlockedAt', 'animatedColorsUnlockedAt', 'nameColor', 'reels', 'reelsCount', 'lastReelAt']))
          )
        )
      );

      match /userReels/{reelId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['url', 'createdAt', 'userId']) &&
                      incoming().url is string && incoming().url.size() <= 1000000 &&
                      incoming().createdAt is timestamp &&
                      incoming().userId == request.auth.uid;
        allow delete: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      function isParticipant() {
        return isAuthenticated() && request.auth.uid in resource.data.participants;
      }
      function isChatAdmin() {
        return isParticipant() && request.auth.uid in resource.data.admins;
      }

      allow read: if isParticipant();
      allow create: if isValidId(chatId) && isAuthenticated() && request.auth.uid in incoming().participants && isValidChat(incoming());
      allow update: if isParticipant() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['typing'])) ||
        (incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt', 'hiddenFor', 'call', 'participantProfiles'])) ||
        (isChatAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['groupName', 'groupPhoto', 'admins', 'memberRoles', 'isLocked', 'participants']))
      );
      allow delete: if isParticipant() && (!('isGroup' in resource.data) || !resource.data.isGroup || (('admins' in resource.data) && request.auth.uid in resource.data.admins));

      match /messages/{messageId} {
        function getChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        function isLocked() {
          return 'isLocked' in getChat() && getChat().isLocked == true;
        }
        function isSenderAdmin() {
          return ('admins' in getChat()) && request.auth.uid in getChat().admins;
        }

        allow read: if isAuthenticated() && request.auth.uid in getChat().participants;
        allow create: if isValidId(messageId) && isAuthenticated() && 
                      request.auth.uid in getChat().participants &&
                      (!isLocked() || isSenderAdmin()) &&
                      isValidMessage(incoming());
        allow update: if isAuthenticated() && 
                      request.auth.uid in getChat().participants &&
                      (
                        (incoming().diff(existing()).affectedKeys().hasOnly(['read']) && incoming().read == true) ||
                        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions'])) ||
                        (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited']) && isValidMessage(incoming()))
                      );
        allow delete: if isAuthenticated() && 
                      (existing().senderId == request.auth.uid || 
                       request.auth.uid in getChat().participants);
      }
    }

    match /games/{gameId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.players;
      allow create: if isValidId(gameId) && isAuthenticated() && request.auth.uid in incoming().players && isValidGame(incoming());
      allow update: if isAuthenticated() && request.auth.uid in resource.data.players && isValidGame(incoming());
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.players;
    }

    match /calls/{callId} {
      allow create: if isAuthenticated() && isValidId(callId) && incoming().callerId == request.auth.uid && isValidCall(incoming());
      allow read, update, delete: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);

      match /callerCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
      match /receiverCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
